{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSnag",
  "version": "0.1.0",
  "identifier": "com.callmehuyv.open-snag",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "OpenSnag",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "editor",
        "title": "OpenSnag Editor",
        "width": 800,
        "height": 600,
        "center": true,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "OpenSnag Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
